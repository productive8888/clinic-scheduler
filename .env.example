DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Auth.js
AUTH_SECRET="replace-with-a-generated-auth-secret"
AUTH_URL="http://localhost:3000"
# NEXTAUTH_URL can be used instead of AUTH_URL if your deployment prefers it.
# NEXTAUTH_URL="http://localhost:3000"

# Magic-link email transport
EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
EMAIL_FROM="Clinic Scheduler <noreply@example.com>"

# Local development only. Set to true to force real Auth.js locally.
DISABLE_LOCAL_DEV_AUTH="true"


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeRole {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum PTORequestType {
  PERSONAL
  VACATION
  SICK
  EMERGENCY
  PTO
  ABSENCE
  UNAVAILABILITY
  SCHEDULE_CHANGE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REVERSED
  OVERRIDDEN
}

enum ScheduleDayStatus {
  DRAFT
  GENERATED
  PUBLISHED
  LOCKED
}

enum ClinicScenario {
  ROUTINE
  CLINIC_CLOSED
  DOCTOR_OFF_REDUCED_STAFFING
  CUSTOM
}

enum TaskSlotStatus {
  OPEN
  FILLED
  SHORTAGE
  CANCELLED
}

enum TaskSlotRequirementLevel {
  REQUIRED
  DESIRED
  OPTIONAL
  CONDITIONAL
}

enum AssignmentSource {
  GENERATED
  MANUAL_OVERRIDE
  COVERAGE_REPLACEMENT
  IMPORTED
}

enum AssignmentStatus {
  ACTIVE
  REMOVED
  CANCELLED
}

enum SchedulingRuleType {
  PREFER_EMPLOYEE_FOR_TASK
  AVOID_EMPLOYEE_FOR_TASK
  PREFER_EMPLOYEE_TASK
  AVOID_EMPLOYEE_TASK
  PRIORITY_BOOST
  PRIORITY_PENALTY
  PREFERRED_DAY
  MIN_ASSIGNMENTS
  MAX_ASSIGNMENTS
  BACKUP_ONLY
  SKILL_WEIGHT
  CUSTOM
}

enum GenerationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ExportType {
  ICS_CALENDAR
  GOOGLE_CALENDAR
  GOOGLE_SHEETS
  PRINTABLE
}

enum ExportStatus {
  QUEUED
  COMPLETED
  FAILED
}

enum HolidayPayRule {
  PAID_HOLIDAY
  BANK_AS_COMP_TIME
  BANK_AS_PTO
  UNPAID
}

enum ShiftCategory {
  AM
  PM
  SATURDAY
  ENDO
  FLOAT
  OTHER
}

enum FairnessWindowType {
  TWO_WEEKS
  ONE_MONTH
  CUSTOM
}

enum BackgroundTaskPeriodType {
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

enum WorkPatternKind {
  CUSTOM
  ENDOSCOPY_SATURDAY
  NON_ENDOSCOPY_SATURDAY
}

enum EndoscopyCompPolicy {
  BANK_PTO
  BANK_COMP_TIME
  FLAG_ONLY
}

enum PayrollAdjustmentType {
  PTO_DEBIT
  PTO_CREDIT
  NPTO_UNPAID_DEDUCTION
  PAID_HOLIDAY_CREDIT
  COMP_TIME_CREDIT
  COMP_TIME_DEBIT
  MANUAL_ADJUSTMENT
  REVERSAL_ADJUSTMENT
}

model Employee {
  id                    String         @id @default(cuid())
  authProviderId        String?        @unique
  email                 String         @unique
  fullName              String
  role                  EmployeeRole   @default(EMPLOYEE)
  status                EmployeeStatus @default(ACTIVE)
  ptoBalanceHours       Decimal        @default(0) @db.Decimal(7, 2)
  expectedWeeklyHours   Decimal        @default(40) @db.Decimal(6, 2)
  compTimeBalanceHours  Decimal        @default(0) @db.Decimal(7, 2)
  weeklyAssignmentLimit Int?
  workPatternId         String?
  startDate             DateTime       @db.Date
  endDate               DateTime?      @db.Date
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  skills                     EmployeeSkill[]
  availability               WeeklyAvailability[]
  ptoRequests                PTORequest[]                     @relation("EmployeePtoRequests")
  reviewedPtoRequests        PTORequest[]                     @relation("PtoReviewer")
  nptoRequests               NPTORequest[]                    @relation("EmployeeNptoRequests")
  reviewedNptoRequests       NPTORequest[]                    @relation("NptoReviewer")
  assignments                Assignment[]                     @relation("AssignedEmployee")
  assignedAssignments        Assignment[]                     @relation("AssignedByEmployee")
  schedulingRules            SchedulingRule[]                 @relation("RuleEmployee")
  createdSchedulingRules     SchedulingRule[]                 @relation("RuleCreator")
  createdStaffingRules       StaffingRequirementRule[]        @relation("StaffingRuleCreator")
  requestedGenerationRuns    ScheduleGenerationRun[]          @relation("GenerationRequester")
  publishedScheduleDays      ScheduleDay[]                    @relation("SchedulePublisher")
  auditLogs                  AuditLog[]                       @relation("AuditActor")
  exportLogs                 ExportLog[]                      @relation("ExportRequester")
  payrollLedgerEntries       PayrollAdjustmentLedger[]        @relation("PayrollLedgerEmployee")
  createdPayrollEntries      PayrollAdjustmentLedger[]        @relation("PayrollLedgerCreator")
  createdPaidHolidays        PaidHoliday[]                    @relation("PaidHolidayCreator")
  createdShiftTemplates      ShiftTemplate[]                  @relation("ShiftTemplateCreator")
  createdShortageRules       ShortageRule[]                   @relation("ShortageRuleCreator")
  createdBackgroundTasks     BackgroundTaskDefinition[]       @relation("BackgroundTaskCreator")
  ownedBackgroundTasks       BackgroundTaskDefinition[]       @relation("BackgroundTaskOwner")
  eligibleBackgroundTasks    BackgroundTaskEligibleEmployee[]
  workPattern                WorkPattern?                     @relation(fields: [workPatternId], references: [id], onDelete: SetNull)
  createdWorkPatterns        WorkPattern[]                    @relation("WorkPatternCreator")
  createdSchedulePatterns    SchedulePattern[]                @relation("SchedulePatternCreator")
  preferredPatternSlots      SchedulePatternSlot[]            @relation("PatternSlotPreferredEmployee")
  scheduleTargets            EmployeeScheduleTarget[]
  backgroundPullRules        BackgroundPullRule[]             @relation("BackgroundPullEmployee")
  createdBackgroundPullRules BackgroundPullRule[]             @relation("BackgroundPullRuleCreator")
  eastonImportReviews        EastonImportReview[]             @relation("EastonImportReviewCreator")

  @@index([status])
  @@index([role])
  @@index([workPatternId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Skill {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees                  EmployeeSkill[]
  taskRequirements           TaskSkillRequirement[]
  backgroundTaskRequirements BackgroundTaskRequiredSkill[]
}

model EmployeeSkill {
  employeeId String
  skillId    String
  assignedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([employeeId, skillId])
}

model TaskType {
  id                   String   @id @default(cuid())
  code                 String   @unique
  name                 String
  description          String?
  interchangeableGroup String?
  difficultyWeight     Int      @default(0)
  active               Boolean  @default(true)
  optional             Boolean  @default(false)
  defaultForRoutine    Boolean  @default(true)
  defaultForReduced    Boolean  @default(true)
  isPatientFacing      Boolean  @default(true)
  isClinical           Boolean  @default(true)
  isBackground         Boolean  @default(false)
  isSkilled            Boolean  @default(false)
  isEndoscopy          Boolean  @default(false)
  isFloat              Boolean  @default(false)
  isClosureCandidate   Boolean  @default(false)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  skillRequirements    TaskSkillRequirement[]
  taskSlots            TaskSlot[]
  schedulingRules      SchedulingRule[]
  staffingRules        StaffingRequirementRule[]
  shortageRules        ShortageRule[]
  schedulePatternSlots SchedulePatternSlot[]

  @@index([active, sortOrder])
  @@index([optional])
  @@index([isPatientFacing, isClinical, isBackground])
  @@index([isClosureCandidate])
  @@index([interchangeableGroup])
}

model TaskSkillRequirement {
  id         String  @id @default(cuid())
  taskTypeId String
  skillId    String
  required   Boolean @default(true)

  taskType TaskType @relation(fields: [taskTypeId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([taskTypeId, skillId])
}

model WeeklyAvailability {
  id                 String    @id @default(cuid())
  employeeId         String
  weekday            Int
  startMinute        Int
  endMinute          Int
  effectiveStartDate DateTime  @db.Date
  effectiveEndDate   DateTime? @db.Date
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, weekday, active])
}

model PTORequest {
  id                   String         @id @default(cuid())
  employeeId           String
  type                 PTORequestType
  status               RequestStatus  @default(PENDING)
  startDate            DateTime       @db.Date
  endDate              DateTime       @db.Date
  startMinute          Int?
  endMinute            Int?
  shortNotice          Boolean        @default(false)
  reason               String?
  managerNote          String?
  reviewedByEmployeeId String?
  reviewedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  employee   Employee  @relation("EmployeePtoRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy Employee? @relation("PtoReviewer", fields: [reviewedByEmployeeId], references: [id])

  @@index([employeeId, status, startDate, endDate])
  @@index([status])
}

model NPTORequest {
  id                    String        @id @default(cuid())
  employeeId            String
  status                RequestStatus @default(PENDING)
  startDate             DateTime      @db.Date
  endDate               DateTime      @db.Date
  startMinute           Int?
  endMinute             Int?
  requestedHours        Decimal       @db.Decimal(8, 2)
  unpaidHours           Decimal       @default(0) @db.Decimal(8, 2)
  capSnapshotHours      Decimal       @default(240) @db.Decimal(8, 2)
  usedHoursAtSubmission Decimal       @default(0) @db.Decimal(8, 2)
  shortNotice           Boolean       @default(false)
  reason                String?
  denialReason          String?
  managerNote           String?
  reviewedByEmployeeId  String?
  reviewedAt            DateTime?
  payrollProcessedAt    DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  employee   Employee  @relation("EmployeeNptoRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy Employee? @relation("NptoReviewer", fields: [reviewedByEmployeeId], references: [id])

  @@index([employeeId, status, startDate, endDate])
  @@index([status])
}

model TimeOffSettings {
  id           String   @id @default("default")
  nptoCapHours Decimal  @default(240) @db.Decimal(8, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PayrollSettings {
  id                               String              @id @default("default")
  defaultPayrollPeriodDays         Int                 @default(14)
  fullTimeWeeklyHours              Decimal             @default(40) @db.Decimal(6, 2)
  paidHolidayDefaultHours          Decimal             @default(8) @db.Decimal(6, 2)
  compTimeBankingEnabled           Boolean             @default(false)
  bankOverExpectedHours            Boolean             @default(false)
  deductUnderExpectedHours         Boolean             @default(false)
  flagUnderExpectedHours           Boolean             @default(true)
  endoscopyExtraHoursPolicy        EndoscopyCompPolicy @default(BANK_PTO)
  endoscopyShortenShiftSuggestions Boolean             @default(false)
  createdAt                        DateTime            @default(now())
  updatedAt                        DateTime            @updatedAt
}

model PaidHoliday {
  id                  String         @id @default(cuid())
  date                DateTime       @unique @db.Date
  name                String
  hours               Decimal        @default(8) @db.Decimal(6, 2)
  rule                HolidayPayRule @default(PAID_HOLIDAY)
  active              Boolean        @default(true)
  notes               String?
  createdByEmployeeId String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  createdBy Employee? @relation("PaidHolidayCreator", fields: [createdByEmployeeId], references: [id])

  @@index([date, active])
  @@index([createdByEmployeeId])
}

model ScheduleDay {
  id                    String            @id @default(cuid())
  date                  DateTime          @unique @db.Date
  status                ScheduleDayStatus @default(DRAFT)
  scenario              ClinicScenario    @default(ROUTINE)
  notes                 String?
  publishedAt           DateTime?
  publishedByEmployeeId String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  shiftBlocks ShiftBlock[]
  taskSlots   TaskSlot[]
  publishedBy Employee?    @relation("SchedulePublisher", fields: [publishedByEmployeeId], references: [id])

  @@index([publishedByEmployeeId])
}

model ShiftTemplate {
  id                  String        @id @default(cuid())
  name                String
  dayOfWeek           Int?
  startMinute         Int
  endMinute           Int
  paidHours           Decimal       @db.Decimal(6, 2)
  shiftCategory       ShiftCategory @default(OTHER)
  defaultForSchedule  Boolean       @default(false)
  active              Boolean       @default(true)
  effectiveStartDate  DateTime?     @db.Date
  effectiveEndDate    DateTime?     @db.Date
  notes               String?
  createdByEmployeeId String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  createdBy            Employee?                 @relation("ShiftTemplateCreator", fields: [createdByEmployeeId], references: [id])
  shiftBlocks          ShiftBlock[]
  staffingRules        StaffingRequirementRule[]
  shortageRules        ShortageRule[]
  schedulePatternSlots SchedulePatternSlot[]

  @@index([active, dayOfWeek])
  @@index([shiftCategory, active])
  @@index([defaultForSchedule])
  @@index([effectiveStartDate, effectiveEndDate])
  @@index([createdByEmployeeId])
}

model ShiftBlock {
  id                 String        @id @default(cuid())
  scheduleDayId      String
  shiftTemplateId    String?
  name               String
  startMinute        Int
  endMinute          Int
  paidHours          Decimal       @db.Decimal(6, 2)
  shiftCategory      ShiftCategory @default(OTHER)
  defaultForSchedule Boolean       @default(false)
  source             String        @default("TEMPLATE")
  active             Boolean       @default(true)
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  scheduleDay   ScheduleDay    @relation(fields: [scheduleDayId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  taskSlots     TaskSlot[]

  @@unique([scheduleDayId, shiftTemplateId])
  @@index([scheduleDayId, active])
  @@index([shiftTemplateId])
  @@index([shiftCategory, startMinute])
}

model TaskSlot {
  id                        String                   @id @default(cuid())
  scheduleDayId             String
  shiftBlockId              String
  taskTypeId                String
  slotIndex                 Int                      @default(1)
  label                     String?
  startMinute               Int?
  endMinute                 Int?
  minStaff                  Int                      @default(1)
  requiredStaff             Int                      @default(1)
  requirementLevel          TaskSlotRequirementLevel @default(REQUIRED)
  source                    String                   @default("DEFAULT")
  staffingRequirementRuleId String?
  status                    TaskSlotStatus           @default(OPEN)
  shortNotice               Boolean                  @default(false)
  notes                     String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  scheduleDay             ScheduleDay              @relation(fields: [scheduleDayId], references: [id], onDelete: Cascade)
  shiftBlock              ShiftBlock               @relation(fields: [shiftBlockId], references: [id], onDelete: Cascade)
  taskType                TaskType                 @relation(fields: [taskTypeId], references: [id])
  staffingRequirementRule StaffingRequirementRule? @relation(fields: [staffingRequirementRuleId], references: [id], onDelete: SetNull)
  assignments             Assignment[]

  @@unique([scheduleDayId, shiftBlockId, taskTypeId, slotIndex])
  @@index([scheduleDayId, status])
  @@index([shiftBlockId])
  @@index([staffingRequirementRuleId])
}

model StaffingRequirementRule {
  id                  String                   @id @default(cuid())
  taskTypeId          String
  shiftTemplateId     String?
  shiftCategory       ShiftCategory?
  weekday             Int?
  scenario            ClinicScenario?
  minRequiredSlots    Int                      @default(1)
  desiredSlots        Int                      @default(1)
  maxSlots            Int                      @default(1)
  requirementLevel    TaskSlotRequirementLevel @default(DESIRED)
  active              Boolean                  @default(true)
  effectiveStartDate  DateTime?                @db.Date
  effectiveEndDate    DateTime?                @db.Date
  notes               String?
  createdByEmployeeId String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  taskType      TaskType       @relation(fields: [taskTypeId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  createdBy     Employee?      @relation("StaffingRuleCreator", fields: [createdByEmployeeId], references: [id])
  taskSlots     TaskSlot[]

  @@index([active, taskTypeId])
  @@index([shiftTemplateId, shiftCategory])
  @@index([weekday, scenario])
  @@index([effectiveStartDate, effectiveEndDate])
}

model FairnessSetting {
  id                       String             @id @default("default")
  windowType               FairnessWindowType @default(TWO_WEEKS)
  customStartDate          DateTime?          @db.Date
  customEndDate            DateTime?          @db.Date
  clinicalShiftWeight      Int                @default(20)
  totalShiftWeight         Int                @default(10)
  totalHoursWeight         Int                @default(8)
  saturdayShiftWeight      Int                @default(12)
  endoscopyShiftWeight     Int                @default(12)
  patternConsistencyWeight Int                @default(35)
  patientFacingShiftWeight Int                @default(20)
  skillRoleBalanceWeight   Int                @default(15)
  exposureGoalWeight       Int                @default(12)
  backgroundPenaltyWeight  Int                @default(20)
  active                   Boolean            @default(true)
  notes                    String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
}

model WorkPattern {
  id                          String          @id @default(cuid())
  code                        String          @unique
  name                        String
  kind                        WorkPatternKind @default(CUSTOM)
  targetWeeklyHours           Decimal         @default(40) @db.Decimal(6, 2)
  worksTuesdayThroughSaturday Boolean         @default(false)
  saturdayPaidHours           Decimal?        @db.Decimal(6, 2)
  mondayOffAllowed            Boolean         @default(false)
  fridayOffAllowed            Boolean         @default(false)
  earlyStartDaysPerWeek       Int             @default(0)
  active                      Boolean         @default(true)
  notes                       String?
  createdByEmployeeId         String?
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  createdBy Employee?  @relation("WorkPatternCreator", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)
  employees Employee[]

  @@index([active, kind])
  @@index([createdByEmployeeId])
}

model ShortageRule {
  id                  String          @id @default(cuid())
  taskTypeId          String?
  shiftTemplateId     String?
  shiftCategory       ShiftCategory?
  scenario            ClinicScenario?
  closurePriority     Int             @default(100)
  managerInstruction  String
  active              Boolean         @default(true)
  effectiveStartDate  DateTime?       @db.Date
  effectiveEndDate    DateTime?       @db.Date
  notes               String?
  createdByEmployeeId String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  taskType      TaskType?      @relation(fields: [taskTypeId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  createdBy     Employee?      @relation("ShortageRuleCreator", fields: [createdByEmployeeId], references: [id])

  @@index([active, closurePriority])
  @@index([taskTypeId, shiftTemplateId, shiftCategory])
  @@index([scenario])
  @@index([effectiveStartDate, effectiveEndDate])
  @@index([createdByEmployeeId])
}

model BackgroundTaskCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  definitions BackgroundTaskDefinition[]

  @@index([active, sortOrder])
}

model BackgroundTaskDefinition {
  id                      String                   @id @default(cuid())
  categoryId              String
  name                    String
  description             String?
  estimatedHoursPerPeriod Decimal                  @db.Decimal(6, 2)
  periodType              BackgroundTaskPeriodType @default(WEEKLY)
  customPeriodDays        Int?
  priority                Int                      @default(100)
  mentor                  String?
  primaryOwnerEmployeeId  String?
  canBePulledForClinic    Boolean                  @default(false)
  protectedFromPull       Boolean                  @default(false)
  rolloverAllowed         Boolean                  @default(true)
  active                  Boolean                  @default(true)
  notes                   String?
  createdByEmployeeId     String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  category          BackgroundTaskCategory           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  primaryOwner      Employee?                        @relation("BackgroundTaskOwner", fields: [primaryOwnerEmployeeId], references: [id], onDelete: SetNull)
  createdBy         Employee?                        @relation("BackgroundTaskCreator", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)
  eligibleEmployees BackgroundTaskEligibleEmployee[]
  requiredSkills    BackgroundTaskRequiredSkill[]
  instances         BackgroundTaskInstance[]

  @@index([categoryId, active])
  @@index([priority, active])
  @@index([primaryOwnerEmployeeId])
  @@index([createdByEmployeeId])
}

model BackgroundPullRule {
  id                  String    @id @default(cuid())
  employeeId          String
  priorityRank        Int
  maxPullsPerPeriod   Int?
  active              Boolean   @default(true)
  effectiveStartDate  DateTime? @db.Date
  effectiveEndDate    DateTime? @db.Date
  notes               String?
  createdByEmployeeId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  employee  Employee  @relation("BackgroundPullEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy Employee? @relation("BackgroundPullRuleCreator", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)

  @@unique([employeeId])
  @@index([active, priorityRank])
  @@index([effectiveStartDate, effectiveEndDate])
  @@index([createdByEmployeeId])
}

model SchedulePattern {
  id                  String    @id @default(cuid())
  code                String    @unique
  name                String
  description         String?
  source              String    @default("MANUAL")
  active              Boolean   @default(true)
  effectiveStartDate  DateTime? @db.Date
  effectiveEndDate    DateTime? @db.Date
  createdByEmployeeId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  createdBy Employee?                @relation("SchedulePatternCreator", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)
  slots     SchedulePatternSlot[]
  targets   EmployeeScheduleTarget[]

  @@index([active, source])
  @@index([effectiveStartDate, effectiveEndDate])
  @@index([createdByEmployeeId])
}

model SchedulePatternSlot {
  id                  String                   @id @default(cuid())
  patternId           String
  weekday             Int
  shiftTemplateId     String?
  shiftCategory       ShiftCategory?
  taskTypeId          String
  slotIndex           Int                      @default(1)
  preferredEmployeeId String?
  requirementLevel    TaskSlotRequirementLevel @default(REQUIRED)
  sourceLabel         String?
  notes               String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  pattern           SchedulePattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  shiftTemplate     ShiftTemplate?  @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  taskType          TaskType        @relation(fields: [taskTypeId], references: [id], onDelete: Cascade)
  preferredEmployee Employee?       @relation("PatternSlotPreferredEmployee", fields: [preferredEmployeeId], references: [id], onDelete: SetNull)

  @@index([patternId, weekday])
  @@index([shiftTemplateId, shiftCategory])
  @@index([taskTypeId])
  @@index([preferredEmployeeId])
}

model EmployeeScheduleTarget {
  id                  String   @id @default(cuid())
  patternId           String?
  employeeId          String?
  employeeName        String
  periodLabel         String?
  targetPatientShifts Decimal? @db.Decimal(8, 2)
  targetTotalHours    Decimal? @db.Decimal(8, 2)
  targetTaskCounts    Json?
  exposureGoals       Json?
  source              String   @default("EASTON_SPREADSHEET")
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  pattern  SchedulePattern? @relation(fields: [patternId], references: [id], onDelete: Cascade)
  employee Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([patternId])
  @@index([employeeId])
  @@index([employeeName])
}

model EastonImportReview {
  id                  String    @id @default(cuid())
  sourcePath          String
  workbookModifiedAt  DateTime?
  status              String    @default("PARSED")
  summary             Json
  warnings            Json?
  createdByEmployeeId String?
  createdAt           DateTime  @default(now())
  appliedAt           DateTime?

  createdBy Employee? @relation("EastonImportReviewCreator", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([createdByEmployeeId])
}

model BackgroundTaskEligibleEmployee {
  definitionId String
  employeeId   String

  definition BackgroundTaskDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  employee   Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([definitionId, employeeId])
}

model BackgroundTaskRequiredSkill {
  definitionId String
  skillId      String

  definition BackgroundTaskDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  skill      Skill                    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([definitionId, skillId])
}

model BackgroundTaskInstance {
  id               String   @id @default(cuid())
  definitionId     String
  periodStartDate  DateTime @db.Date
  periodEndDate    DateTime @db.Date
  estimatedHours   Decimal  @db.Decimal(6, 2)
  prioritySnapshot Int
  status           String   @default("OPEN")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  definition BackgroundTaskDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([definitionId, periodStartDate, periodEndDate])
  @@index([periodStartDate, periodEndDate])
  @@index([status])
}

model Assignment {
  id                   String           @id @default(cuid())
  taskSlotId           String
  employeeId           String
  source               AssignmentSource @default(GENERATED)
  status               AssignmentStatus @default(ACTIVE)
  locked               Boolean          @default(false)
  shortNotice          Boolean          @default(false)
  assignedByEmployeeId String?
  generationRunId      String?
  assignedAt           DateTime         @default(now())
  removedAt            DateTime?
  notes                String?

  taskSlot      TaskSlot               @relation(fields: [taskSlotId], references: [id], onDelete: Cascade)
  employee      Employee               @relation("AssignedEmployee", fields: [employeeId], references: [id])
  assignedBy    Employee?              @relation("AssignedByEmployee", fields: [assignedByEmployeeId], references: [id])
  generationRun ScheduleGenerationRun? @relation(fields: [generationRunId], references: [id])

  @@index([employeeId, status])
  @@index([taskSlotId, status])
  @@index([generationRunId])
}

model SchedulingRule {
  id                  String             @id @default(cuid())
  type                SchedulingRuleType
  employeeId          String?
  taskTypeId          String?
  weight              Int                @default(0)
  priority            Int                @default(0)
  active              Boolean            @default(true)
  effectiveStartDate  DateTime?          @db.Date
  effectiveEndDate    DateTime?          @db.Date
  parameters          Json?
  notes               String?
  createdByEmployeeId String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  employee  Employee? @relation("RuleEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  taskType  TaskType? @relation(fields: [taskTypeId], references: [id], onDelete: Cascade)
  createdBy Employee? @relation("RuleCreator", fields: [createdByEmployeeId], references: [id])

  @@index([active, type])
  @@index([employeeId, taskTypeId])
}

model ScheduleGenerationRun {
  id                    String           @id @default(cuid())
  dateStart             DateTime         @db.Date
  dateEnd               DateTime         @db.Date
  seed                  String
  engineVersion         String
  inputHash             String
  status                GenerationStatus @default(PENDING)
  requestedByEmployeeId String?
  summary               Json?
  createdAt             DateTime         @default(now())
  completedAt           DateTime?

  requestedBy Employee?    @relation("GenerationRequester", fields: [requestedByEmployeeId], references: [id])
  assignments Assignment[]

  @@index([dateStart, dateEnd])
  @@index([status])
}

model AuditLog {
  id              String   @id @default(cuid())
  actorEmployeeId String?
  action          String
  entityType      String
  entityId        String?
  before          Json?
  after           Json?
  metadata        Json?
  createdAt       DateTime @default(now())

  actor Employee? @relation("AuditActor", fields: [actorEmployeeId], references: [id])

  @@index([entityType, entityId])
  @@index([actorEmployeeId])
  @@index([createdAt])
}

model ExportLog {
  id                    String       @id @default(cuid())
  type                  ExportType
  status                ExportStatus @default(QUEUED)
  requestedByEmployeeId String?
  scheduleDayId         String?
  outputUrl             String?
  metadata              Json?
  errorMessage          String?
  createdAt             DateTime     @default(now())
  completedAt           DateTime?

  requestedBy Employee? @relation("ExportRequester", fields: [requestedByEmployeeId], references: [id])

  @@index([type, status])
}

model PayrollAdjustmentLedger {
  id                  String                @id @default(cuid())
  employeeId          String
  type                PayrollAdjustmentType
  hours               Decimal               @db.Decimal(8, 2)
  effectiveDate       DateTime              @db.Date
  periodStartDate     DateTime?             @db.Date
  periodEndDate       DateTime?             @db.Date
  sourceEntityType    String?
  sourceEntityId      String?
  createdByEmployeeId String?
  metadata            Json?
  notes               String?
  createdAt           DateTime              @default(now())

  employee  Employee  @relation("PayrollLedgerEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy Employee? @relation("PayrollLedgerCreator", fields: [createdByEmployeeId], references: [id])

  @@unique([employeeId, type, sourceEntityType, sourceEntityId])
  @@index([employeeId, effectiveDate])
  @@index([periodStartDate, periodEndDate])
  @@index([type])
  @@index([sourceEntityType, sourceEntityId])
  @@index([createdByEmployeeId])
}
